# ── Roblox AI Plugin Backend Configuration ────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Provider (pick one) ────────────────────────────────────
# Leave AI_PROVIDER blank to auto-detect from whichever key exists.
# AI_PROVIDER=qwen
# AI_PROVIDER=openai

# ── Qwen (free tier via Alibaba Cloud / DashScope) ───────────
# Get your key at: https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-key-here
# QWEN_MODEL=qwen3-coder-plus
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenAI (alternative, paid) ────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ── Vision model for reference image analysis ─────────────────
# qwen-vl-plus works on the Qwen free tier (qwen-vl-max does NOT on free tier)
VISION_MODEL=qwen-vl-plus
# VISION_API_KEY=  (defaults to QWEN_API_KEY — no separate key needed)
VISION_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Server ────────────────────────────────────────────────────
PORT=3000
